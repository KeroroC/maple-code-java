# MapleCode 示例配置
# 复制到 ./maplecode.yaml 或 ~/.maplecode/config.yaml 后修改。

protocol: anthropic            # "anthropic" | "openai"
model: claude-sonnet-4-6
base_url: https://api.anthropic.com
api_key: ${ANTHROPIC_API_KEY} # ${ENV_VAR} 占位符，从环境变量解析

system_prompt: |
  You are MapleCode, a helpful coding assistant. Be concise.

extended_thinking:             # 可选；OpenAI 忽略此块
  type: adaptive               # "adaptive"（推荐） | "enabled"（legacy，Opus 4.7 上返回 400）
  effort: high                 # adaptive 时：low | medium | high
  # budget_tokens: 10000       # 仅 enabled 时：>= 1024 且 < max_tokens

permission_mode: default       # "strict"（未匹配直接拒绝） | "default"（未匹配走人回路） | "permissive"（未匹配直接放行）
                               # 运行时可通过 /mode 命令热切；重启后回到此处配置
                               # 规则文件（优先级从低到高）：
                               #   ~/.maplecode/permissions.yaml        用户全局
                               #   <项目>/.maplecode/permissions.yaml   项目级（应入 git）
                               #   <项目>/.maplecode/permissions.local.yaml  项目本地（应入 .gitignore）
                               # 格式示例：
                               #   rules:
                               #     - tool: exec
                               #       pattern: "git *"
                               #       action: allow

timeouts:
  connect_seconds: 10
  read_seconds: 60

agent:
  max_iterations: 50           # 单轮对话最大工具调用轮数（默认 50）
  max_consecutive_unknown: 3   # 连续调用未知工具达到此次数后停止（默认 3）

# MCP（Model Context Protocol）server 列表。默认开启。
# 三层配置文件（优先级从低到高，同 key 后者覆盖前者，子 map deep-merge）：
#   ~/.maplecode/mcp_servers.yaml            用户全局（跨项目共享）
#   <项目>/.maplecode/mcp_servers.yaml       项目级（应入 git）
#   <项目>/.maplecode/mcp_servers.local.yaml 项目本地（应入 .gitignore）
# server 文件格式示例：
#   servers:
#     github:
#       type: stdio
#       command: npx
#       args: ["-y", "@modelcontextprotocol/server-github"]
#       env:
#         GITHUB_TOKEN: ${GITHUB_TOKEN}
#     notion:
#       type: http
#       url: https://mcp.notion.example.com/mcp
#       headers:
#         Authorization: "Bearer ${NOTION_TOKEN}"
mcp_servers:
  enabled: true
  startup_timeout_ms: 5000

# ===== v6 上下文管理 =====

# 上下文窗口总 token 数（输入预算，不含 max_tokens 输出预算）
# 默认 200000，覆盖 Sonnet 4.6 / Opus 4.7 / Haiku 4.5
# GPT-4o 用户请调到 128000；调试时也可临时调小（如 30000）触发次层摘要
# 未配则走默认 200000
# context_window: 200000

# 摘要专用 model（可选）；未配则用主对话 model
# 推荐 claude-haiku-4-5：便宜、快，5 段结构化摘要任务足够
# 配错 model 名会在第一次 /compress 或自动压缩时由 provider 返回 HTTP 4xx
# summarizer_model: claude-haiku-4-5

# ===== v7.3 自动长期记忆 =====

# 每轮 Agent Loop 结束后异步调 LLM 分析对话，自动新增/修改/删除长期记忆。
# 记忆在下次启动时注入系统提示词，实现跨会话知识积累。
# memory:
#   enabled: true
#   memory_model: claude-haiku-4-5    # 记忆提取用模型（可选，默认复用主模型）
#   max_context_messages: 10          # 提取时看最近几条消息（默认 10）

# ===== v8 Skill 系统 =====

# Skill 文件存放目录（三级优先级：项目 > 用户 > 内置）：
#   .maplecode/skills/          # 项目级（最高优先级）
#   ~/.maplecode/skills/        # 用户级
#   内置资源                     # 最低优先级（commit, review, test）
#
# Skill 文件格式（YAML frontmatter + Markdown 正文）：
#   ---
#   name: my-skill
#   description: 一句话说明
#   tools: [exec, read_file]     # 工具白名单（可选，为空则不限制）
#   mode: shared                 # 执行模式：shared（共享对话）| independent（独立执行）
#   history_depth: 5             # independent 模式下带多少历史（可选）
#   model: claude-haiku-4-5      # 指定模型（可选）
#   ---
#   # Skill 指令
#   这里是发给模型的 SOP 指令...
#   {{input}}                    # 用户输入的占位符
#
# 使用方式：
#   /skill list                  # 列出所有可用 Skills
#   /skill activate <name>       # 激活 Skill
#   /skill deactivate <name>     # 停用 Skill
#   /skill info <name>           # 查看 Skill 详情
#
# 模型也可以通过 load_skill 工具自动加载 Skill。